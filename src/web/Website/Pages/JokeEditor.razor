@page "/jokeeditor"
@attribute [Authorize(Roles = "Admin")]
@using MudBlazor
<PageTitle>Joke Editor</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudPaper Elevation="2" Class="pa-4">
        <MudText Typo="Typo.h4" GutterBottom="true">Joke Editor</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">Manage and edit jokes in the database.</MudText>

        @if (isLoading)
        {
            <div class="d-flex flex-column align-center my-5">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mt-2">Loading jokes...</MudText>
            </div>
        }
        else if (editingJoke != null && isAddingNew)
        {
            <!-- Add New Joke - Vertical Layout -->
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h5" Class="mb-4">Add New Joke</MudText>

                <!-- Joke Text -->
                <MudTextField @bind-Value="editingJoke.JokeTxt"
                              Label="Joke Text"
                              Variant="Variant.Outlined"
                              Lines="4"
                              Required="true"
                              Class="mb-4" />

                <!-- Attribution -->
                <MudTextField @bind-Value="editingJoke.Attribution"
                              Label="Attribution (optional)"
                              Variant="Variant.Outlined"
                              Class="mb-4" />

                <!-- Categories with Auto-Assign button -->
                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-1">
                    <div class="flex-grow-1">
                        <MudSelect T="int"
                                   Label="Categories"
                                   Variant="Variant.Outlined"
                                   MultiSelection="true"
                                   @bind-SelectedValues="selectedCategoryIds"
                                   MultiSelectionTextFunc="@(new Func<List<string>, string>(GetSelectedCategoriesText))">
                            @foreach (var category in allCategories)
                            {
                                <MudSelectItem T="int" Value="@category.JokeCategoryId">@category.JokeCategoryTxt</MudSelectItem>
                            }
                        </MudSelect>
                    </div>
                    <MudTooltip Text="Let AI suggest categories for this joke">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.AutoAwesome"
                                   OnClick="SuggestCategoriesAsync"
                                   Disabled="@(isSuggestingCategories || string.IsNullOrWhiteSpace(editingJoke.JokeTxt))">
                            Auto-Assign
                        </MudButton>
                    </MudTooltip>
                </MudStack>
                @if (isSuggestingCategories)
                {
                    <div class="d-flex align-center mb-3">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" Class="mr-2" />
                        <MudText Typo="Typo.body2">Asking AI to suggest categories...</MudText>
                    </div>
                }
                else
                {
                    <div class="mb-4"></div>
                }

                @if (!string.IsNullOrEmpty(editMessage) && currentWizardStep == 0)
                {
                    <MudAlert Severity="@GetAlertSeverity()" Class="mb-3">@editMessage</MudAlert>
                }

                @if (currentWizardStep == 0)
                {
                    <!-- Initial navigation: Next to reveal image section -->
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="NextWizardStep"
                                   Disabled="@(isSuggestingCategories)">
                            Next
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   OnClick="CancelEdit">
                            Cancel
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <!-- Image section (revealed after Next) -->
                    <MudDivider Class="my-4" />
                    <MudText Typo="Typo.h6" Class="mb-3">Joke Image</MudText>

                    @if (isGeneratingScenario || isGeneratingImage)
                    {
                        <div class="d-flex flex-column align-center my-5">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                            <MudText Typo="Typo.body2" Class="mt-2">
                                @(isGeneratingScenario ? "Creating scene description..." : "Asking artist AI to create an image...")
                            </MudText>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(jokeImageUrl) && jokeImageUrl != "skipped")
                    {
                        <!-- Image generated: show preview and description -->
                        <div class="mb-4">
                            <img src="@jokeImageUrl" alt="Generated joke image" class="joke-image-preview" />
                        </div>
                        @if (!string.IsNullOrEmpty(editingJoke.ImageTxt))
                        {
                            <MudTextField @bind-Value="editingJoke.ImageTxt"
                                          Label="Scene Description"
                                          Variant="Variant.Outlined"
                                          Lines="3"
                                          Class="mb-3" />
                        }
                        <MudStack Row="true" Spacing="2" Class="mb-4">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       Color="Color.Secondary"
                                       OnClick="RegenerateWizardImageAsync"
                                       StartIcon="@Icons.Material.Filled.Refresh">
                                Regenerate Image
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       OnClick="ClearWizardImage"
                                       StartIcon="@Icons.Material.Filled.Clear">
                                Remove Image
                            </MudButton>
                        </MudStack>
                    }
                    else
                    {
                        <!-- No image yet: offer to create one -->
                        <MudStack Row="true" Spacing="2" Class="mb-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Image"
                                       OnClick="CreateJokeImageAsync">
                                Create an Image of this Joke
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       StartIcon="@Icons.Material.Filled.SkipNext"
                                       OnClick="SkipImageGeneration">
                                Skip Image
                            </MudButton>
                        </MudStack>
                    }

                    @if (!string.IsNullOrEmpty(editMessage))
                    {
                        <MudAlert Severity="@GetAlertSeverity()" Class="mb-3">@editMessage</MudAlert>
                    }

                    <!-- Save / Back / Cancel -->
                    <MudStack Row="true" Spacing="2">
                        @if (!string.IsNullOrEmpty(jokeImageUrl))
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       OnClick="SaveJoke"
                                       Disabled="@(isSaving || isGeneratingImage || isGeneratingScenario)"
                                       StartIcon="@Icons.Material.Filled.Save">
                                @if (isSaving)
                                {
                                    <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                                }
                                Save Joke
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   OnClick="PreviousWizardStep"
                                   Disabled="@(isSuggestingCategories || isGeneratingScenario || isGeneratingImage || isSaving)">
                            Back
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Default"
                                   OnClick="CancelEdit"
                                   Disabled="@(isSaving)">
                            Cancel
                        </MudButton>
                    </MudStack>
                }
            </MudPaper>
        }
        else if (editingJoke != null && !isAddingNew)
        {
            <!-- Edit Existing Joke -->
            <MudPaper Elevation="1" Class="pa-4">
                <MudText Typo="Typo.h5" Class="mb-4">Edit Joke #@editingJoke.JokeId</MudText>

                <MudTextField @bind-Value="editingJoke.JokeTxt"
                              Label="Joke Text"
                              Variant="Variant.Outlined"
                              Lines="4"
                              Class="mb-4" />

                <MudTextField @bind-Value="editingJoke.Attribution"
                              Label="Attribution"
                              Variant="Variant.Outlined"
                              Class="mb-4" />

                <MudStack Row="true" Spacing="2" Class="mb-4" AlignItems="AlignItems.Center">
                    <div class="flex-grow-1">
                        <MudTextField @bind-Value="editingJoke.ImageTxt"
                                      Label="Image Description"
                                      Variant="Variant.Outlined"
                                      Lines="2" />
                    </div>
                    <MudTooltip Text="Re-generate Scenario">
                        <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome"
                                       Color="Color.Secondary"
                                       Variant="Variant.Outlined"
                                       OnClick="RegenerateScenarioAsync"
                                       Disabled="@(isGeneratingScenario || isSaving)" />
                    </MudTooltip>
                </MudStack>
                @if (isGeneratingScenario)
                {
                    <div class="d-flex align-center mb-3">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" Class="mr-2" />
                        <MudText Typo="Typo.body2">Generating scene description...</MudText>
                    </div>
                }

                <MudSelect T="int"
                           Label="Categories"
                           Variant="Variant.Outlined"
                           MultiSelection="true"
                           @bind-SelectedValues="selectedCategoryIds"
                           MultiSelectionTextFunc="@(new Func<List<string>, string>(GetSelectedCategoriesText))"
                           Class="mb-4">
                    @foreach (var category in allCategories)
                    {
                        <MudSelectItem T="int" Value="@category.JokeCategoryId">@category.JokeCategoryTxt</MudSelectItem>
                    }
                </MudSelect>

                <!-- Image display -->
                <MudPaper Class="pa-3 mb-4" Outlined="true">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Joke Image</MudText>
                    @if (!string.IsNullOrEmpty(jokeImageUrl))
                    {
                        <div class="mb-3">
                            <img src="@jokeImageUrl" alt="Joke image" class="joke-image-preview" />
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">No image yet.</MudText>
                    }
                    @if (isGeneratingImage)
                    {
                        <div class="d-flex align-center mb-2">
                            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small" Class="mr-2" />
                            <MudText Typo="Typo.body2">Generating image...</MudText>
                        </div>
                    }
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Image"
                               OnClick="RegenerateImageAsync"
                               Disabled="@(isGeneratingImage || isSaving)">
                        Re-generate Image
                    </MudButton>
                </MudPaper>

                <MudPaper Class="pa-3 mb-4" Outlined="true">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Created By</MudText>
                            <MudText Typo="Typo.body2">@editingJoke.CreateUserName on @FormatLocalDateTime(editingJoke.CreateDateTime)</MudText>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Last Changed By</MudText>
                            <MudText Typo="Typo.body2">@editingJoke.ChangeUserName on @FormatLocalDateTime(editingJoke.ChangeDateTime)</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <MudStack Row="true" Spacing="2" Class="mb-3">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="SaveJoke"
                               Disabled="@isSaving">
                        @if (isSaving)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        }
                        Save Changes
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               OnClick="CancelEdit"
                               Disabled="@isSaving">
                        Cancel
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete"
                               OnClick="ConfirmDeleteJoke"
                               Disabled="@isSaving">
                        Delete
                    </MudButton>
                </MudStack>

                @if (!string.IsNullOrEmpty(editMessage))
                {
                    <MudAlert Severity="@GetAlertSeverity()" Class="mt-3">@editMessage</MudAlert>
                }
            </MudPaper>
        }
        else
        {
            <!-- List View -->
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddNewJoke">
                    Add New Joke
                </MudButton>
            </MudStack>
            <MudStack Spacing="3" Class="mb-4">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="searchText"
                                      Label="Search"
                                      Placeholder="Search jokes..."
                                      Variant="Variant.Outlined"
                                      Immediate="true"
                                      DebounceInterval="300"
                                      OnDebounceIntervalElapsed="FilterJokes"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Search" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudSelect Value="categoryFilter"
                                   Label="Category"
                                   Variant="Variant.Outlined"
                                   ValueChanged="@((string val) => { categoryFilter = val; FilterJokes(); })">
                            <MudSelectItem Value="@("")">All Categories</MudSelectItem>
                            @foreach (var category in allCategories)
                            {
                                <MudSelectItem Value="@category.JokeCategoryTxt">@category.JokeCategoryTxt</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudStack>

            <MudDataGrid T="Joke"
                         Items="@filteredJokes"
                         Striped="true"
                         Hover="true"
                         SortMode="SortMode.Multiple"
                         Filterable="false"
                         Dense="true"
                         Class="mb-4">
                <Columns>
                    <PropertyColumn Property="x => x.JokeId" Title="ID" />
                    <TemplateColumn Title="Joke" Sortable="true" SortBy="@_sortByJokeText">
                        <CellTemplate>
                            <MudText Typo="Typo.body2">
                                @(context.Item.JokeTxt != null ? (context.Item.JokeTxt.Length > 100 ? context.Item.JokeTxt.Substring(0, 100) + "..." : context.Item.JokeTxt) : "")
                            </MudText>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.Categories" Title="Categories" />
                    <PropertyColumn Property="x => x.Attribution" Title="Attribution" />
                    <TemplateColumn Title="Actions" Sortable="false">
                        <CellTemplate>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => EditJoke(context.Item.JokeId))">
                                Edit
                            </MudButton>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="Joke" />
                </PagerContent>
            </MudDataGrid>

            <MudText Typo="Typo.body2">
                Total Jokes: @(filteredJokes?.Count() ?? 0) of @(allJokes?.Count() ?? 0)
            </MudText>
        }
    </MudPaper>
</MudContainer>

