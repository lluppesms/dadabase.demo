@page "/export"
@attribute [Authorize(Roles = "Admin")]
<PageTitle>Export / Import Data</PageTitle>

<div class="container" style="padding: 25px;">

    @* ── SQL Export ──────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-body">
            <h1>Export Joke Data</h1>
            <p>Export all jokes and categories from the database.</p>

            <div class="d-flex flex-wrap gap-3 mt-4">
                <button class="btn btn-primary" @onclick="DownloadSqlExport" disabled="@isBusy">
                    @if (isBusy && activeAction == "sql")
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="fas fa-database me-2"></i>Download SQL Export
                </button>

                <button class="btn btn-secondary" @onclick="DownloadTabExport" disabled="@isBusy">
                    @if (isBusy && activeAction == "tab")
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="fas fa-file-alt me-2"></i>Download Tab-Delimited Export
                </button>
            </div>

            @if (!string.IsNullOrEmpty(exportStatusMessage))
            {
                <div class="alert @exportAlertClass mt-3" role="alert">
                    @exportStatusMessage
                </div>
            }
        </div>
    </div>

    @* ── Tab-Delimited Import ─────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-body">
            <h2>Import Jokes from Tab-Delimited File</h2>
            <p>
                Select a tab-delimited (<code>.tsv</code> or <code>.txt</code>) file previously exported from this application.
                New jokes and categories will be added; existing jokes (matched by joke text) are skipped.
            </p>

            <div class="mb-3">
                <label class="form-label fw-semibold" for="importFile">Select file:</label>
                <InputFile id="importFile" class="form-control" accept=".tsv,.txt,.tab" OnChange="OnImportFileSelected" disabled="@isBusy" />
            </div>

            @if (!string.IsNullOrEmpty(importFileName))
            {
                <p class="text-muted small mb-3">Selected: <strong>@importFileName</strong></p>
            }

            <button class="btn btn-success" @onclick="RunImport" disabled="@(isBusy || importFileContent == null)">
                @if (isBusy && activeAction == "import")
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="fas fa-upload me-2"></i>Import Jokes
            </button>

            @if (!string.IsNullOrEmpty(importStatusMessage))
            {
                <div class="alert @importAlertClass mt-3" role="alert">
                    @importStatusMessage
                </div>
            }
        </div>
    </div>
</div>
